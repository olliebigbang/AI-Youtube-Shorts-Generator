{
  "_comment": "Wan2.1 T2V workflow for concept_maker.py - requires ComfyUI-WanVideoWrapper (kijai)",
  "_setup": [
    "1. 在ComfyUI UI里打开你的Wan2.1 T2V workflow",
    "2. 按 Ctrl+Shift+S 导出为 API 格式",
    "3. 用导出的JSON替换本文件内容（保留 _comment 和 _setup 注释行没关系）",
    "4. 找到正向提示词字段，将其值改为字符串 __PROMPT__",
    "5. 找到帧数字段（num_frames / length / frame_number 等），将其值改为数字 0 再手动改为字符串 __FRAMES__",
    "   注意：JSON中数字字段要写成不带引号的 __FRAMES__，代码会替换为整数",
    "模型文件名参考：",
    "  - Wan2_1-T2V-14B_fp8_e4m3fn.safetensors",
    "  - Wan2_1-T2V-1_3B_fp8_e4m3fn.safetensors (轻量版)"
  ],
  "1": {
    "class_type": "DownloadAndLoadWanModel",
    "inputs": {
      "model": "Wan2_1-T2V-14B_fp8_e4m3fn.safetensors",
      "base_precision": "fp8_e4m3fn",
      "quantization": "disabled",
      "load_device": "main_device",
      "attention_mode": "sdpa"
    }
  },
  "2": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "umt5_xxl_fp8_e4m3fn.safetensors",
      "type": "wan"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__PROMPT__",
      "clip": ["2", 0]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "text, watermark, logo, nsfw, blurry, low quality, static, frozen",
      "clip": ["2", 0]
    }
  },
  "5": {
    "class_type": "WanEmptyLatentVideo",
    "inputs": {
      "width": 480,
      "height": 832,
      "length": "__FRAMES__",
      "batch_size": 1
    }
  },
  "6": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["5", 0],
      "seed": 0,
      "steps": 20,
      "cfg": 6.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0
    }
  },
  "7": {
    "class_type": "VAEDecodeTiled",
    "inputs": {
      "samples": ["6", 0],
      "vae": ["1", 2],
      "tile_size": 272,
      "overlap": 64,
      "temporal_size": 64,
      "temporal_overlap": 8
    }
  },
  "8": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["7", 0],
      "frame_rate": 24,
      "loop_count": 0,
      "filename_prefix": "concept_scene",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 19,
      "save_metadata": false,
      "pingpong": false,
      "save_output": true
    }
  }
}
